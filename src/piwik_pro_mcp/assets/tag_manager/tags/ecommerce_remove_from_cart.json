{
  "extends": "tag_base_ecommerce",
  "template_name": "ecommerce_remove_from_cart",
  "name_aliases": [
    "Ecommerce Remove from Cart Tag"
  ],
  "description": "Collects data about products removed from the cart. Reads from the data layer (GA4, Universal Analytics, or custom). Map product fields to your data structure. Use a Data layer event trigger (e.g. remove_from_cart). Cannot be used together with ecommerce cart update tag. Respect opt-out and DNT is on by default.",
  "ai_usage_guide": {
    "when_to_use": [
      "Tracking remove-from-cart events from ecommerce data layer",
      "Understanding cart abandonment and product removal",
      "Pairing with add-to-cart for full cart lifecycle tracking",
      "GA4 or Universal Analytics remove_from_cart events"
    ],
    "common_use_cases": [
      "Remove from cart button clicks",
      "Cart abandonment analysis",
      "Product removal patterns",
      "Cart funnel optimization"
    ]
  },
  "required_attributes": {
    "consent_type": {
      "default": "analytics",
      "examples": [
        "analytics",
        "conversion_tracking"
      ]
    },
    "template": {
      "description": "Must be 'ecommerce_remove_from_cart' for this template",
      "value": "ecommerce_remove_from_cart",
      "validation": {
        "required": true,
        "fixed_value": "ecommerce_remove_from_cart"
      }
    },
    "template_options": {
      "type": "object",
      "description": "Ecommerce configuration. Must include product_mapping, category_mapping_type, products_array.",
      "mutability": "editable",
      "validation": {
        "required": true
      },
      "required": [
        "product_mapping",
        "category_mapping_type",
        "products_array"
      ]
    },
    "template_options.products_array": {
      "type": "string",
      "description": "Source of product array in data layer. E.g. '{{ ecommerce }}.items' or '{{ items }}'.",
      "mutability": "editable",
      "validation": {
        "required": true
      },
      "example": "{{ ecommerce }}.items"
    },
    "template_options.product_mapping": {
      "type": "object",
      "description": "Map data layer keys to product fields. sku is required; others optional.",
      "mutability": "editable",
      "validation": {
        "required": true
      },
      "required": [
        "sku"
      ],
      "properties": {
        "sku": "Key for product SKU (required)",
        "name": "Key for product name",
        "category": "Key for main category",
        "price": "Key for price",
        "quantity": "Key for quantity",
        "brand": "Key for brand",
        "variant": "Key for variant (e.g. size, color)"
      }
    },
    "template_options.category_mapping_type": {
      "type": "string",
      "description": "How to handle subcategories. disabled | split_by_delimiter | use_mapping.",
      "mutability": "editable",
      "validation": {
        "required": true
      },
      "options": {
        "disabled": "No subcategories",
        "split_by_delimiter": "Categories in single field, separated by / (UA style)",
        "use_mapping": "Separate keys for category2-5 (GA4 style)"
      }
    }
  },
  "optional_attributes": {
    "template_options.currency": {
      "type": "string",
      "description": "Source of currency. Variable syntax or key path.",
      "mutability": "editable"
    },
    "template_options.category_mapping": {
      "type": "object",
      "description": "When category_mapping_type is use_mapping: keys for category2-5.",
      "mutability": "editable",
      "properties": {
        "category2": "string",
        "category3": "string",
        "category4": "string",
        "category5": "string"
      }
    },
    "template_options.custom_dimensions": {
      "type": "array",
      "description": "Custom dimensions for the event. Each has id (1-400) and value.",
      "mutability": "editable"
    },
    "template_options.product_dimensions": {
      "type": "array",
      "description": "Product-level custom dimensions. Each has id (1-20) and value.",
      "mutability": "editable"
    },
    "is_active": {
      "description": "Whether the tag is active"
    },
    "priority": {
      "description": "Firing order",
      "range": "0 to 4294967295"
    },
    "disable_in_debug_mode": {
      "description": "Disable when Tag Manager is in debug mode"
    },
    "respect_visitors_privacy": {
      "description": "Respect DNT header and opt-out (on by default for this tag)"
    }
  },
  "field_mutability_guide": {
    "mutability_types": {
      "editable": {
        "examples": [
          "name",
          "is_active",
          "priority",
          "consent_type",
          "template_options.*"
        ]
      },
      "create-only": {
        "examples": [
          "template"
        ]
      },
      "read-only": {
        "examples": [
          "created_at",
          "updated_at",
          "is_published",
          "tag_id"
        ]
      }
    }
  },
  "complete_examples": {
    "custom_remove": {
      "description": "Custom data layer (remove_from_cart event)",
      "mcp_call": {
        "function": "tags_create",
        "parameters": {
          "app_id": "12345678-1234-1234-1234-123456789012",
          "attributes": {
            "name": "Remove from Cart - Custom",
            "template": "ecommerce_remove_from_cart",
            "template_options": {
              "products_array": "{{ items }}",
              "currency": "currency",
              "product_mapping": {
                "sku": "item_id",
                "name": "item_name",
                "price": "price",
                "quantity": "quantity",
                "category": "item_category",
                "brand": "item_brand",
                "variant": "item_color"
              },
              "category_mapping_type": "use_mapping",
              "category_mapping": {
                "category2": "item_category2",
                "category3": "item_category3"
              }
            },
            "consent_type": "conversion_tracking"
          },
          "triggers": "remove-from-cart-trigger-uuid"
        }
      },
      "prerequisite": "Create Data layer event trigger with event name 'remove_from_cart' (GA4) or 'removeFromCart' (UA)."
    },
    "ga4_preset": {
      "description": "Using dataLayerGA4 preset",
      "mcp_call": {
        "function": "tags_create",
        "parameters": {
          "app_id": "12345678-1234-1234-1234-123456789012",
          "attributes": {
            "name": "Remove from Cart - GA4",
            "template": "ecommerce_remove_from_cart",
            "template_options": {
              "products_array": "{{ ecommerce }}.items",
              "currency": "{{ ecommerce }}.currency",
              "product_mapping": {
                "sku": "item_id",
                "name": "item_name",
                "category": "item_category",
                "price": "price",
                "quantity": "quantity",
                "brand": "item_brand",
                "variant": "item_variant"
              },
              "category_mapping_type": "use_mapping",
              "category_mapping": {
                "category2": "item_category2",
                "category3": "item_category3",
                "category4": "item_category4",
                "category5": "item_category5"
              }
            },
            "consent_type": "conversion_tracking"
          },
          "triggers": "remove-from-cart-trigger-uuid"
        }
      }
    }
  },
  "common_mistakes": [
    "Using together with ecommerce cart update tag (they conflict)",
    "Omitting product_mapping.sku (required)",
    "Wrong event name for trigger (remove_from_cart vs removeFromCart for GA4 vs UA)",
    "Wrong products_array path for your data layer"
  ],
  "troubleshooting": {
    "no_data_collected": [
      "Verify Data layer event trigger with correct event name (remove_from_cart/removeFromCart)",
      "Check products_array path matches your data layer",
      "Ensure product_mapping keys match your product object structure"
    ]
  }
}

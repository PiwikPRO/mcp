{
  "extends": "tag_base",
  "template_name": "bing_ads",
  "name_aliases": [
    "Microsoft Universal Event Tracking (Bing Ads)",
    "Bing Ads"
  ],
  "description": "Microsoft Universal Event Tracking (UET) tag for Bing Ads. Collects user activity data on your website and reports it in Microsoft Advertising for conversion tracking and remarketing. Get your UET ID from Microsoft Advertising > Campaigns > Conversion tracking > UET tag.",
  "ai_usage_guide": {
    "when_to_use": [
      "Bing Ads / Microsoft Advertising campaign tracking",
      "Conversion tracking for Microsoft Advertising",
      "Remarketing and audience building for Bing Ads"
    ],
    "common_use_cases": [
      "Track conversions from Bing Ads campaigns",
      "Retarget website visitors with Microsoft Advertising",
      "Measure campaign ROI in Microsoft Advertising"
    ]
  },
  "required_attributes": {
    "consent_type": {
      "default": "marketing_automation",
      "examples": [
        "remarketing",
        "marketing_automation"
      ]
    },
    "template": {
      "description": "Must be 'bing_ads' for this template",
      "value": "bing_ads",
      "validation": {
        "required": true,
        "fixed_value": "bing_ads"
      }
    },
    "template_options": {
      "type": "object",
      "description": "Bing Ads configuration. Must include id (UET tag ID).",
      "mutability": "editable",
      "validation": {
        "required": true
      },
      "required": [
        "id"
      ]
    },
    "template_options.id": {
      "type": "string",
      "description": "Universal Event Tracking Tag id. Find in Microsoft Advertising > Campaigns > Conversion tracking > UET tag.",
      "mutability": "editable",
      "validation": {
        "required": true,
        "min_length": 1
      },
      "example": "123456789",
      "variable_reference_allowed": true
    }
  },
  "optional_attributes": {
    "respect_visitors_privacy": {
      "description": "Respect DNT header and opt-out. Off by default.",
      "mutability": "editable",
      "default": false
    },
    "is_active": {
      "description": "Whether the tag is active"
    },
    "priority": {
      "description": "Firing order",
      "range": "0 to 4294967295"
    },
    "disable_in_debug_mode": {
      "description": "Disable when Tag Manager is in debug mode"
    },
    "scheduler": {
      "description": "Flight dates"
    }
  },
  "field_mutability_guide": {
    "mutability_types": {
      "editable": {
        "examples": [
          "name",
          "template_options.id",
          "consent_type",
          "respect_visitors_privacy",
          "is_active",
          "priority"
        ]
      },
      "create-only": {
        "examples": [
          "template"
        ]
      },
      "read-only": {
        "examples": [
          "created_at",
          "updated_at",
          "is_published",
          "tag_id"
        ]
      }
    }
  },
  "complete_examples": {
    "basic": {
      "description": "Bing Ads UET tag on all pages",
      "mcp_call": {
        "function": "tags_create",
        "parameters": {
          "app_id": "12345678-1234-1234-1234-123456789012",
          "attributes": {
            "name": "Bing Ads UET",
            "template": "bing_ads",
            "template_options": {
              "id": "123456789"
            },
            "consent_type": "remarketing"
          },
          "triggers": "pageview-trigger-uuid"
        }
      },
      "prerequisite": "Get UET ID from Microsoft Advertising > Campaigns > Conversion tracking > UET tag. Use page_view trigger."
    },
    "update_example": {
      "description": "Update UET ID or consent",
      "mcp_call": {
        "function": "tags_update",
        "parameters": {
          "app_id": "12345678-1234-1234-1234-123456789012",
          "tag_id": "87654321-4321-4321-4321-210987654321",
          "attributes": {
            "template_options": {
              "id": "123456789"
            },
            "consent_type": "remarketing"
          },
          "triggers": "__unchanged__"
        }
      }
    }
  },
  "common_mistakes": [
    "Using wrong UET ID - copy from Microsoft Advertising UET tag setup",
    "Omitting template_options or id",
    "Forgetting to attach page_view trigger"
  ],
  "troubleshooting": {
    "conversions_not_tracking": [
      "Verify UET ID is correct (Microsoft Advertising > Conversion tracking > UET tag)",
      "Ensure trigger fires (use page_view for base tag)",
      "Check consent_type matches your consent form"
    ],
    "tag_not_firing": [
      "Verify triggers are attached",
      "Check consent_type is met",
      "Ensure tag is_active is true"
    ]
  }
}
